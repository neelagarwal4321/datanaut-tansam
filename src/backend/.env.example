# Copy to .env and fill in values

# REQUIRED for production — leave blank to disable auth (dev mode only)
API_SECRET=

# REQUIRED for production — 64-char hex string (32 bytes) for AES-256-GCM credential encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Server port (default: 8085)
PORT=8085

# Restrict CORS to a specific origin — comma-separated for multiple
# Leave blank to allow all origins (acceptable on localhost)
CORS_ORIGIN=
